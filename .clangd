CompileFlags:
  Add:
    - -std=c++20
    - -xc++
    - -Wall
    - -Wextra
    - -Wno-nested-anon-types
    - -Wno-unused-parameter
    - -Wno-unused-variable
    - -Wno-unused-function
    - -Wno-unused-private-field
    - -Wno-missing-field-initializers
    - -Wno-deprecated-declarations
    - -Wno-c++17-extensions
    - -Wno-unknown-pragmas
    - -Wno-unused-but-set-variable
    - -Wno-unused-command-line-argument
    - -Wno-format-security
    - -Wno-format-nonliteral
    - -Wno-sign-compare
    - -Wno-shadow
    - -Wno-implicit-fallthrough
    - -Wno-maybe-uninitialized
    - -Wno-return-type
    - -Wno-missing-braces
    - -Wno-parentheses
    - -Wno-switch
    - -Wno-unused-result
    - -Wno-strict-overflow
    - -Wno-array-bounds
    - -Wno-attributes
    - -Wno-unknown-warning-option
    - -D_SILENCE_ALL_CXX17_DEPRECATION_WARNINGS
    - -D_SILENCE_ALL_MS_EXT_DEPRECATION_WARNINGS
    - -DNOMINMAX
    - -DWIN32_LEAN_AND_MEAN
    - -D_CRT_SECURE_NO_WARNINGS
    - -DSOLSTICE_EXPORTS
    - -I.
    - -Isource/
  Remove:
    - -W*
    - -w
    - -std=*
Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
  ClangTidy:
    Add:
      - readability-*
      - performance-*
      - modernize-*
    Remove:
      - readability-uppercase-literal-suffix
      - readability-identifier-length
      - modernize-use-trailing-return-type
      - modernize-avoid-c-arrays
      - modernize-use-auto
      - modernize-use-using
      - performance-*
    CheckOptions:
      # Naming conventions - PascalCase for classes, functions, parameters, members
      readability-identifier-naming.NamespaceCase: CamelCase
      readability-identifier-naming.ClassCase: CamelCase
      readability-identifier-naming.StructCase: CamelCase
      readability-identifier-naming.UnionCase: CamelCase
      readability-identifier-naming.FunctionCase: CamelCase
      readability-identifier-naming.ParameterCase: CamelCase
      readability-identifier-naming.VariableCase: CamelCase
      readability-identifier-naming.MemberCase: CamelCase
      readability-identifier-naming.MemberPrefix: m_
      readability-identifier-naming.PrivateMemberCase: CamelCase
      readability-identifier-naming.PrivateMemberPrefix: m_
      readability-identifier-naming.ProtectedMemberCase: CamelCase
      readability-identifier-naming.ProtectedMemberPrefix: m_
      readability-identifier-naming.PublicMemberCase: CamelCase
      readability-identifier-naming.PublicMemberPrefix: ""
      readability-identifier-naming.ConstantCase: UPPER_CASE
      readability-identifier-naming.ConstantMemberCase: UPPER_CASE
      readability-identifier-naming.ConstantMemberPrefix: ""
      readability-identifier-naming.StaticConstantCase: UPPER_CASE
      readability-identifier-naming.StaticConstantPrefix: ""
      readability-identifier-naming.EnumCase: CamelCase
      readability-identifier-naming.EnumConstantCase: UPPER_CASE
      readability-identifier-naming.TypedefCase: CamelCase
      readability-identifier-naming.TypeAliasCase: CamelCase
      readability-identifier-naming.TemplateParameterCase: CamelCase
      readability-identifier-naming.GlobalConstantCase: UPPER_CASE
      readability-identifier-naming.GlobalConstantPrefix: ""
      readability-identifier-naming.GlobalFunctionCase: CamelCase
      readability-identifier-naming.GlobalVariableCase: CamelCase
      readability-identifier-naming.StaticVariableCase: CamelCase
      readability-identifier-naming.StaticVariablePrefix: ""
      readability-identifier-naming.UnionMemberCase: CamelCase
      readability-identifier-naming.UnionMemberPrefix: ""
      readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
      readability-identifier-naming.MacroDefinitionPrefix: ""
      # Include sorting
      readability-include-order.IncludeBlocks: Regroup
      readability-include-order.SortIncludes: true
      readability-include-order.StrictMode: true
Index:
  Background: Build

