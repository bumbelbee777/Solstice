+#if BX_PLATFORM_WINDOWS && BX_COMPILER_MSVC
+	// Helper to set thread name via RaiseException; in separate function to avoid
+	// MSVC C2712 (__try in function that requires object unwinding).
+	static void setThreadNameException(DWORD threadId, LPCSTR name)
+	{
+#	pragma pack(push, 8)
+		struct ThreadName
+		{
+			DWORD  type;
+			LPCSTR name;
+			DWORD  id;
+			DWORD  flags;
+		};
+#	pragma pack(pop)
+		ThreadName tn;
+		tn.type  = 0x1000;
+		tn.name  = name;
+		tn.id    = threadId;
+		tn.flags = 0;
+		__try
+		{
+			RaiseException(0x406d1388, 0, sizeof(tn)/4, reinterpret_cast<ULONG_PTR*>(&tn) );
+		}
+		__except(EXCEPTION_EXECUTE_HANDLER)
+		{
+		}
+	}
+#endif // BX_PLATFORM_WINDOWS && BX_COMPILER_MSVC
